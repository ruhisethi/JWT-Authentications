def add_accent_bar(doc: Document, text: str, fill: str = LIGHT_BLUE, border: str = TEAL) -> None:
    """Add a one-row callout band for key ideas or chapter summaries."""
    table = doc.add_table(rows=1, cols=1)
    table.alignment = WD_TABLE_ALIGNMENT.CENTER
    table.autofit = False
    table.allow_autofit = False
    set_column_widths(table, [6.8])
