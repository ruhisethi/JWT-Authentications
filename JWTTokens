def add_bullets(doc: Document, items: Iterable[str]) -> None:
    """Add a compact bullet list."""
    for item in items:
        p = doc.add_paragraph(style="List Bullet")
        p.add_run(item)


def add_numbered(doc: Document, items: Iterable[str]) -> None:
    """Add a compact manually numbered list that restarts in each section."""
    for idx, item in enumerate(items, 1):
        p = doc.add_paragraph()
        p.paragraph_format.left_indent = Inches(0.24)
        p.paragraph_format.first_line_indent = Inches(-0.24)
        p.paragraph_format.space_after = Pt(3)
        p.add_run(f"{idx}. {item}")


def add_table(
    doc: Document,
    headers: Sequence[str],
    rows: Sequence[Sequence[str]],
    widths: Sequence[float],
    header_fill: str = NAVY,
) -> None:
    """Add a styled data table with non-cramped padding and repeated header text."""
    table = doc.add_table(rows=1, cols=len(headers))
    table.alignment = WD_TABLE_ALIGNMENT.CENTER
    table.autofit = False
    table.allow_autofit = False
    set_column_widths(table, widths)
    set_table_borders(table)

    header_cells = table.rows[0].cells
    for idx, header in enumerate(headers):
        shade_cell(header_cells[idx], header_fill)
        set_cell_margins(header_cells[idx], 115, 130, 115, 130)
        set_cell_text(header_cells[idx], header, bold=True, color=WHITE, size=9.3)

    for row_idx, row_values in enumerate(rows):
        row_cells = table.add_row().cells
        for col_idx, value in enumerate(row_values):
            if row_idx % 2 == 1:
                shade_cell(row_cells[col_idx], "FAFBFC")
            set_cell_margins(row_cells[col_idx], 110, 130, 110, 130)
            set_cell_text(row_cells[col_idx], value, size=9.1)
    doc.add_paragraph()


def add_code_block(doc: Document, code: str) -> None:
    """Add code-like pseudocode in a shaded one-cell table so it stays readable."""
    table = doc.add_table(rows=1, cols=1)
    table.alignment = WD_TABLE_ALIGNMENT.CENTER
    table.autofit = False
    table.allow_autofit = False
    set_column_widths(table, [6.8])
    set_table_borders(table, "C7D2DD")
    cell = table.cell(0, 0)
    shade_cell(cell, "F8FAFC")
    set_cell_margins(cell, 130, 160, 130, 160)
    paragraph = cell.paragraphs[0]
    paragraph.text = ""
    paragraph.paragraph_format.space_after = Pt(0)
    for idx, line in enumerate(code.strip("\n").splitlines()):
        if idx:
            paragraph.add_run().add_break()
        run = paragraph.add_run(line)
        run.font.name = "Consolas"
        run._element.rPr.rFonts.set(qn("w:ascii"), "Consolas")
        run._element.rPr.rFonts.set(qn("w:hAnsi"), "Consolas")
        run.font.size = Pt(8.4)
        run.font.color.rgb = RGBColor.from_string("243B53")
    doc.add_paragraph()


